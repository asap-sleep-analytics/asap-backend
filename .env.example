# Base de datos
# Fallback local con SQLite
# DATABASE_URL=sqlite:///./asap.db

# URL de produccion para Neon / PostgreSQL
# Acepta `postgresql://...` (Neon por defecto) y también `postgresql+psycopg://...`.
# El backend normaliza automáticamente a `postgresql+psycopg://...`.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>/<database>?sslmode=require
AUTO_CREATE_TABLES=false

# Doble opt-in
LEAD_CONFIRM_URL_BASE=https://api.asap-health.app/api/leads/confirm
LEAD_TOKEN_TTL_HOURS=24

# Seleccion de proveedor SMTP: custom | resend | sendgrid | gmail
SMTP_PROVIDER=sendgrid

# Overrides opcionales para cualquier proveedor
SMTP_HOST=
SMTP_PORT=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# Credenciales
# Resend: SMTP_USERNAME por defecto es 'resend'
# SendGrid: SMTP_USERNAME por defecto es 'apikey'
# Gmail: define SMTP_USERNAME con tu cuenta y usa App Password
SMTP_USERNAME=
SMTP_PASSWORD=

# Remitente
SMTP_FROM_NAME=A.S.A.P.
SMTP_FROM_EMAIL=no-reply@asap-health.app
SMTP_REPLY_TO=support@asap-health.app

# Auth JWT
AUTH_SECRET_KEY=<cambia-esta-clave>
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRES_MINUTES=43200
AUTH_ISSUER=asap-backend

# Admin export
ADMIN_DATASET_EXPORT_KEY=<cambia-esta-clave-admin>

# ML de sueno
# Ruta local del modelo de Scikit-Learn (joblib). Si no existe, se usa fallback heuristico.
ML_SLEEP_MODEL_PATH=./artifacts/sleep_model.joblib
